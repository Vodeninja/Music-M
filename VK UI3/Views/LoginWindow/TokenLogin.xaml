<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="VK_UI3.Views.LoginWindow.TokenLogin"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:VK_UI3.Views.LoginWindow"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid
		Margin="50"
		HorizontalAlignment="Center"
		VerticalAlignment="Center"
		Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}"
		CornerRadius="8"
		Translation="0,0,8">
		<Grid.Shadow>
			<ThemeShadow />
		</Grid.Shadow>

		<ScrollView>
			<StackPanel
				Margin="50"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Translation="0,0,8">

				<TextBlock
					Margin="0,0,0,4"
					FontSize="20"
					FontWeight="SemiBold"
					Text="Вход по токену"
					AutomationProperties.Name="Вход по токену" />

				<TextBlock
					Margin="0,0,0,16"
					Opacity="0.6"
					TextWrapping="Wrap"
					MaxWidth="300"
					Text="Введите access_token вашего аккаунта ВКонтакте." />

				<TextBox
					x:Name="TokenTextBox"
					Width="300"
					PlaceholderText="access_token"
					KeyDown="TokenTextBox_KeyDown"
					AutomationProperties.Name="Поле ввода токена" />

				<TextBlock
					x:Name="errorTextBlock"
					Width="300"
					Margin="0,4,0,0"
					Foreground="Red"
					TextWrapping="WrapWholeWords"
					Visibility="Collapsed" />

				<Button
					Margin="0,16,0,0"
					HorizontalAlignment="Stretch"
					Click="LoginButton_Click"
					Content="Войти"
					Style="{StaticResource AccentButtonStyle}"
					AutomationProperties.Name="Кнопка входа по токену" />

				<Button
					Margin="0,8,0,0"
					HorizontalAlignment="Stretch"
					Click="BackButton_Click"
					Content="Назад"
					AutomationProperties.Name="Кнопка назад" />

			</StackPanel>
		</ScrollView>
	</Grid>
</Page>
