<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="VK_UI3.Views.LoginWindow.QrLogin"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:VK_UI3.Views.LoginWindow"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid
		Margin="50"
		HorizontalAlignment="Center"
		VerticalAlignment="Center"
		Background="{ThemeResource LayerOnAccentAcrylicFillColorDefaultBrush}"
		CornerRadius="8"
		Translation="0,0,8">
		<Grid.Shadow>
			<ThemeShadow />
		</Grid.Shadow>

		<ScrollView>
			<StackPanel
				Margin="50"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Spacing="12"
				Translation="0,0,8">

				<TextBlock
					FontSize="20"
					FontWeight="SemiBold"
					Text="Вход по QR коду"
					AutomationProperties.Name="Вход по QR коду" />

				<TextBlock
					Opacity="0.6"
					TextWrapping="Wrap"
					MaxWidth="280"
					TextAlignment="Center"
					Text="Отсканируйте QR код в приложении ВКонтакте: Профиль → QR код" />

				<Border
					x:Name="QrBorder"
					Width="220"
					Height="220"
					HorizontalAlignment="Center"
					CornerRadius="8"
					Background="White"
					Padding="8">
					<Grid>
						<ProgressRing
							x:Name="LoadingRing"
							IsActive="True"
							Width="48"
							Height="48"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />
						<Image
							x:Name="QrImage"
							Stretch="Uniform"
							Visibility="Collapsed"
							AutomationProperties.Name="QR код для входа" />
					</Grid>
				</Border>

				<TextBlock
					x:Name="StatusText"
					HorizontalAlignment="Center"
					TextAlignment="Center"
					Opacity="0.7"
					Text="Генерация QR кода..." />

				<TextBlock
					x:Name="errorTextBlock"
					Width="280"
					Foreground="Red"
					TextWrapping="WrapWholeWords"
					Visibility="Collapsed" />

				<Button
					x:Name="RefreshButton"
					HorizontalAlignment="Stretch"
					Click="RefreshButton_Click"
					Content="Обновить QR код"
					Visibility="Collapsed"
					AutomationProperties.Name="Обновить QR код" />

				<Button
					Margin="0,4,0,0"
					HorizontalAlignment="Stretch"
					Click="BackButton_Click"
					Content="Назад"
					AutomationProperties.Name="Кнопка назад" />

			</StackPanel>
		</ScrollView>
	</Grid>
</Page>
